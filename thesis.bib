% Пример оформления библиографии для ugost2003

% Книга
% Необходимые поля:
% - Название (title)
% - Автор(ы) (author, разделяются c помощью "and")
% - Город издательства (address)
% - Наименование издательства (publisher)
% - Год издания (year)
% - Общее кол-во страниц (numpages, опционально, либо везде ставить, либо нет)
% Пример оформления русской книги
@book{aleksC++,
  title      = {Современное проектирование на С++},
  author     = {А. Александреску},
  publisher  = {БХВ-Петербург},
  address    = {Санкт"=Петербург},
  year       = {2019},
  language   = {russian}  
}

@book{OOPC++,
  title      = {Объектно-ориентированное программирование в С++},
  author     = {Р. Лафоре},
  publisher  = {Питер},
  address    = {Санкт"=Петербург},
  year       = {2021},
  language   = {russian}  
}

@book{GameDev,
  title      = {Основы разработки игр. Теория и практика.},
  author     = {Е. Шенк},
  publisher  = {Вильямс},
  address    = {Москва},
  year       = {2022},
  language   = {russian}  
}

% Статья
% Необходимые поля:
% - Название статьи (title)
% - Автор(ы) (author, разделяются c помощью "and")
% - Название журнала (journal)
% - Идентификационные данные (хотя бы одно из):
%   - Том (volume)
%   - Номер (number)
%   - Выпуск
% - Год издания (year)
% - Страницы (диапазон в журнале) (pages)
%     Замеч.: страницы всегда оформляются интервалом даже если статья на одну страницу

% Электронный ресурс
% Необходимые поля:
% - URL (url)
% - Заголовок с экрана (title)
% - Дата обращения (urldate, не позднее официальной даты сдачи работы)
% - Язык заголовка с экрана (note)
% Для электронных ресурсов лучше оставлять language = {russian}
% вне зависимости от реального языка источника

% Пример оформления электронного источника на английском языке
@online{raspberryDoc,
  title={Raspberry Pi Documentation},
  url = {https://www.raspberrypi.com/documentation/},
  urldate = {18.05.2026},
  note = {Загл. с экр. Яз. рус.},
  language = {russian}
}
